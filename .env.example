# OpenAI API (Whisper STT + Chat Completions LLM)
OPENAI_API_KEY=sk-your-key-here

# Azure Speech Service (used for TTS + Viseme generation)
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=eastus

# Azure TTS voice (see: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support)
# Fallback voice when automatic language-based selection is unavailable.
AZURE_VOICE_NAME=en-US-Adam:DragonHDLatestNeural

# Azure Translator (Text language detection)
# Used to auto-detect language from TEXT and choose an Azure TTS voice automatically.
# Create a Translator resource (or Cognitive Services multi-service) and copy its key/region.
AZURE_TRANSLATOR_KEY=your-azure-translator-key-here
AZURE_TRANSLATOR_REGION=westeurope
# Advanced: override only if you use a non-default cloud or custom endpoint.
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# LLM: CLI defaults to `--llm ECHO` (free). Use `--llm OPENAI` for Chat Completions (uses LLM_MODEL below; billed).
# LLM prompt body only (shared Signosoft header + safety footer are prepended/appended in code).
# Used when personality YAML omits `llm.system_prompt` or leaves it empty.
LLM_SYSTEM_PROMPT=You are a generic Signosoft demo assistant. Be clear, friendly, and accurate. Do not impersonate any real person or fictional character.
# Chat model and reply length cap (spoken output stays short via personality prompts)
LLM_MODEL=gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=512
