# OpenAI API (used for Whisper STT and future GPT-4o LLM)
OPENAI_API_KEY=sk-your-key-here

# Azure Speech Service (used for TTS + Viseme generation)
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=eastus

# Azure TTS voice (see: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support)
AZURE_VOICE_NAME=en-US-JennyNeural

# LLM settings
LLM_SYSTEM_PROMPT=You are a helpful assistant.
